{
  "name": "lonelynathan",
  "version": "0.10.0",
  "main": "out/main/index.js",
  "scripts": {
    "check": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check --write .",
    "dev": "electron-vite dev",
    "start": "pnpm dev",
    "clean": "rimraf out dist",
    "build": "pnpm clean && electron-vite build && electron-builder --publish never",
    "build:linux": "pnpm clean && electron-vite build && electron-builder --linux --publish never",
    "build:mac": "pnpm clean && electron-vite build && electron-builder --mac --publish never",
    "build:win": "pnpm clean && electron-vite build && electron-builder --win --publish never"
  },
  "homepage": "https://lonelynathan.app",
  "bugs": {
    "url": "https://github.com/kkomelin/n8n-ollama-desktop/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kkomelin/n8n-ollama-desktop.git"
  },
  "keywords": [
    "n8n",
    "ollama",
    "electron",
    "desktop",
    "docker",
    "ai",
    "automation",
    "n8n-ollama-desktop",
    "lonelynathan"
  ],
  "author": "Konstantin Komelin <konstantin.komelin@gmail.com>",
  "license": "Apache-2.0",
  "description": "LonelyNathan — n8n + Ollama Desktop App",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "lefthook"
    ]
  },
  "build": {
    "appId": "app.lonelynathan.LonelyNathan",
    "productName": "LonelyNathan",
    "copyright": "Licensed under Apache-2.0.",
    "files": [
      "out/**/*",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": "compose.yaml",
        "to": "compose.yaml"
      },
      {
        "from": "compose.cpu.yaml",
        "to": "compose.cpu.yaml"
      },
      {
        "from": "compose.amd.yaml",
        "to": "compose.amd.yaml"
      },
      {
        "from": "compose.nvidia.yaml",
        "to": "compose.nvidia.yaml"
      },
      {
        "from": "ollama-credentials.json",
        "to": "ollama-credentials.json"
      },
      {
        "from": "assets/linux/icons/512x512.png",
        "to": "assets/linux/icons/512x512.png"
      },
      {
        "from": "assets/windows/icon.ico",
        "to": "assets/windows/icon.ico"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office",
      "icon": "assets/linux/icons"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/macos/icon.icns"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/windows/icon.ico"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.2",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lefthook": "^2.1.4",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.2"
  }
}
